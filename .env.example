# =============================================================================
# .env.example  —  Tier-2 Fact-Check LLM  —  Checkpoint A
#
# Copy to .env and adjust values before running locally outside Docker.
# docker-compose reads this file automatically.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=factcheck
POSTGRES_USER=factcheck
POSTGRES_PASSWORD=factcheck
# Full DSN — overrides the individual vars above if set
# DATABASE_URL=postgresql://factcheck:factcheck@localhost:5432/factcheck

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Full URL — overrides the individual vars above if set
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# RQ
# ---------------------------------------------------------------------------
RQ_QUEUE_NAME=verify
RQ_JOB_TIMEOUT=300

# ---------------------------------------------------------------------------
# FastAPI / uvicorn
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to false to disable idempotency checks during load testing
IDEMPOTENCY_CHECK=true

# ---------------------------------------------------------------------------
# Docker host port bindings (only relevant for docker-compose)
# ---------------------------------------------------------------------------
POSTGRES_PORT_EXTERNAL=5432
REDIS_PORT_EXTERNAL=6379
API_PORT_EXTERNAL=8000
